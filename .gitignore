# Generated caches
__pycache__/
*.pyc
.cache/

# Secrets and browser/app state that should not be versioned
.ssh/
*.sqlite
*.sqlite-wal
*.sqlite-shm
logins.json
key4.db
cookies.sqlite
pulse/cookie

# Large/local binaries are tracked by manifests instead
*.AppImage
dotfiles/local/bin/orbit

# pipx-generated entry points (user-specific paths)
dotfiles/local/bin/pywalfox

# Build output
target/
src/
pkg/
*.pkg.tar.zst

# Environment
.env
.env.*

# Editor artifacts
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
