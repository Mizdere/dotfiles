+    async fn get_active_wireless_ssid(&self) -> Option<String> {
+        for device_path in self.get_wireless_devices().await.ok()? {
+            let path_obj = zbus::zvariant::ObjectPath::try_from(device_path.as_str()).ok()?;
+            let ap_reply = self.conn
+                .call_method(
+                    Some("org.freedesktop.NetworkManager"),
+                    &path_obj,
+                    Some("org.freedesktop.DBus.Properties"),
+                    "Get",
+                    &("org.freedesktop.NetworkManager.Device.Wireless", "ActiveAccessPoint"),
+                )
+                .await
+                .ok()?;
+
+            let ap_val = ap_reply.body().deserialize::<zbus::zvariant::OwnedValue>().ok()?;
+            let ap_path = zbus::zvariant::OwnedObjectPath::try_from(zbus::zvariant::Value::from(ap_val)).ok()?;
+            if ap_path.as_str() == "/" {
+                continue;
+            }
+
+            let ssid_owned = self.get_ap_property(ap_path.as_str(), "Ssid").await.ok()?;
+            let ssid_bytes: Vec<u8> = match zbus::zvariant::Value::from(ssid_owned) {
+                zbus::zvariant::Value::Array(a) => a.iter().filter_map(|iv| u8::try_from(iv).ok()).collect(),
+                _ => Vec::new(),
+            };
+            let ssid = String::from_utf8_lossy(&ssid_bytes).to_string();
+            if !ssid.is_empty() {
+                return Some(ssid);
+            }
+        }
+
+        None
+    }
+
     pub async fn has_saved_connection(&self, ssid: &str) -> bool {
