[global]
    monitor = 0
    follow = mouse
    width = 320
    height = (0, 200)
    origin = top-right
    offset = (16, 16)
    padding = 10
    horizontal_padding = 10
    frame_width = 1
    frame_color = "#2a2620"
    separator_height = 0
    sort = yes
    idle_threshold = 60

    font = Terminess Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    ellipsize = middle
    show_age_threshold = -1
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = true

    show_indicators = no
    icon_position = off
    min_icon_size = 0
    max_icon_size = 0

    transparency = 10
    corner_radius = 2
    background = "#000000"
    foreground = "#e6e0d0"

[urgency_low]
    timeout = 3

[urgency_normal]
    timeout = 5

[urgency_critical]
    timeout = 0
    frame_color = "#6e2a2a"
