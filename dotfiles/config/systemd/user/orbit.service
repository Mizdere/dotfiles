[Unit]
Description=Orbit WiFi/Bluetooth Manager Daemon
After=network.target graphical-session.target
PartOf=graphical-session.target

[Service]
ExecStartPre=/usr/bin/sh -c 'for i in $(seq 1 30); do [ -n "$WAYLAND_DISPLAY" ] && [ -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ] && exit 0; sleep 1; done; exit 1'
ExecStart=%h/.local/bin/orbit daemon
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
